{
  "name": "ivts-api",
  "version": "1.0.0",
  "description": "IVTS backend service.",
  "main": "server.js",
  "scripts": {
    "test": "DOTENV_CONFIG_PATH=.env.test node -r dotenv/config -r ./test/node-test-setup.js --test server/Project/accounts/service/*.test.js server/Project/settings/service/*.test.js",
    "test:iam-sdk": "node -r ./test/node-test-setup.js --test server/Project/security/service/iam-admin-client.test.js",
    "test:contracts": "node --test test/*.test.js",
    "test:all": "npm run test && npm run test:iam-sdk && npm run test:contracts",
    "migrate:account-hr-context": "node scripts/migrate-account-hr-context.js",
    "register:iam": "node -r dotenv/config scripts/register-ivts-iam-client.js",
    "register:iam:local": "node -r dotenv/config scripts/register-ivts-iam-client.js dotenv_config_path=.env.local",
    "smoke:live:user": "node -r dotenv/config scripts/live-smoke-ivts-user-flow.js dotenv_config_path=.env.local",
    "init:core": "node -r dotenv/config scripts/init-ivts-core.js",
    "bootstrap": "npm run bootstrap:iam",
    "bootstrap:local": "npm run bootstrap:iam:local",
    "bootstrap:permissions": "node -r dotenv/config scripts/bootstrap-ivts-permissions.js",
    "reset:permissions": "node -r dotenv/config scripts/reset-ivts-permissions.js",
    "cleanup:local-security": "node -r dotenv/config scripts/cleanup-local-security-ownership.js",
    "cleanup:audit-retention": "node -r dotenv/config scripts/cleanup-audit-retention.js",
    "seed:e2e-admin": "node -r dotenv/config scripts/seed-e2e-admin.js dotenv_config_path=.env.test",
    "start": "npm run start:local",
    "start:local": "cross-env DOTENV_CONFIG_PATH=.env.local nodemon -r dotenv/config server.js",
    "start:preprod": "cross-env DOTENV_CONFIG_PATH=.env.preprod node -r dotenv/config server.js",
    "start:prod": "cross-env DOTENV_CONFIG_PATH=.env.prod node -r dotenv/config server.js",
    "serve:e2e": "cross-env DOTENV_CONFIG_PATH=.env.test node -r dotenv/config server.js",
    "serve:test": "cross-env DOTENV_CONFIG_PATH=.env.test node -r dotenv/config server.js",
    "serve:prod": "cross-env DOTENV_CONFIG_PATH=.env.prod node -r dotenv/config server.js",
    "bootstrap:permissions:local": "node -r dotenv/config scripts/bootstrap-ivts-permissions.js dotenv_config_path=.env.local",
    "bootstrap:iam": "node -r dotenv/config scripts/bootstrap-iam-permissions.js",
    "bootstrap:iam:local": "node -r dotenv/config scripts/bootstrap-iam-permissions.js dotenv_config_path=.env.local",
    "template:check": "node -c config/project.config.js && node -c scripts/bootstrap-iam-permissions.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.1.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dont-sniff-mimetype": "^1.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.17.1",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^5.3.1",
    "google-auth-library": "^10.6.1",
    "ienoopen": "^1.1.0",
    "lodash": "^4.17.23",
    "moment": "^2.29.4",
    "mongodb": "^6.12.0",
    "mongoose": "^5.13.22",
    "morgan": "^1.9.1",
    "multer": "^1.4.5-lts.1",
    "nocache": "^2.1.0",
    "nodemailer": "^6.9.2",
    "redis": "^4.5.0",
    "socket.io": "^4.7.4",
    "swagger-ui-express": "^4.6.3",
    "winston": "^3.19.0",
    "winston-mongodb": "^6.0.0",
    "x-xss-protection": "^2.0.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "nodemon": "^2.0.20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prongnote/admin-api-master.git"
  },
  "bugs": {
    "url": "https://github.com/prongnote/admin-api-master/issues"
  },
  "homepage": "https://github.com/prongnote/admin-api-master#readme"
}
