# IVTS compose settings - local
COMPOSE_PROJECT_NAME=ivts
BACKEND_BIND_IP=127.0.0.1
BACKEND_PORT=8203
BACKEND_NODE_ENV=development
BACKEND_ENV_FILE=./backend-node/.env.local
FRONTEND_BIND_IP=127.0.0.1
FRONTEND_PORT=8303
BASE_SERVER_URL=http://127.0.0.1:8203
GOOGLE_CLIENT_ID=
GOOGLE_OAUTH_SCOPE="profile email"
GOOGLE_OAUTH_PROMPT=select_account
FRONTEND_AUTH_SYSTEM=ivts
FRONTEND_PROJECT_APP_ID=ivts
FRONTEND_PROJECT_PERMISSION_ROOT_PATH=/ivts/security/permission
